	title = {Labour {Exploitation}, {Gender} {Violence} and {Barriers} to {Reproductive} and {Sexual} {Rights}: {The} {Experiences} of {Migrant} {Women} in {Italian} {Agriculture}},
	copyright = {https://creativecommons.org/licenses/by-sa/4.0},
