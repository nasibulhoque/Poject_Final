@article{vonzabernRebelCauseFraming2021,
	title = {Rebel with a cause: the framing of climate change and intergenerational justice in the {German} press treatment of the {Fridays} for {Future} protests},
	volume = {43},
	issn = {0163-4437, 1460-3675},
	shorttitle = {Rebel with a cause},
	url = {https://journals.sagepub.com/doi/10.1177/0163443720960923},
	doi = {10.1177/0163443720960923},
	abstract = {This study investigates the representation of the Fridays for Future strikes in the German online newspapers Bild.de, Zeit Online and FAZ.net. Through a qualitative and quantitative content analysis over the time period August 2018 to March 2019, eight frames have been identified. Whereas Zeit Online shows a framing towards intergenerational justice, the coverage of FAZ.net and Bild.de strongly adheres to the protest paradigm. The majority of all articles guarantees protesters a voice, but this voice is often reduced to apolitical testimonies and the protesters’ self-agency is undermined through disparagement. German media coverage thus tends to reproduce existing power structures by marginalizing and depoliticizing the political agenda of a system critical protest. Although this framing feeds into the shift of the climate change discourse towards adaptation, the study shows that the idea of climate change as an issue of intergenerational justice and children’s rights has become part of the media’s agenda.},
	language = {en},
	number = {1},
	urldate = {2025-10-26},
	journal = {Media, Culture \& Society},
	author = {Von Zabern, Lena and Tulloch, Christopher D},
	month = jan,
	year = {2021},
	pages = {23--47},
	file = {PDF:C\:\\Users\\shrab\\Zotero\\storage\\3AFJLHLJ\\Von Zabern and Tulloch - 2021 - Rebel with a cause the framing of climate change and intergenerational justice in the German press.pdf:application/pdf},
}

