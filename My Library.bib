	file = {PDF:C\:\\Users\\shrab\\Zotero\\storage\\FD9QYL93\\Pulido - 2017 - Geographies of race and ethnicity II Environmental racism, racial capitalism and state-sanctioned v.pdf:application/pdf},
}

